      "$type": "color",
      "default": { "$value": "{color.neutral.200}" },
      "strong": { "$value": "{color.neutral.300}" },
      "brand": { "$value": "{color.purple.700}" },
      "accent": { "$value": "{color.teal.500}" },
      "focus": { "$value": "{color.teal.500}" },
      "danger": { "$value": "#dc2626" }
    },
    "overlay": {
      "$type": "color",
      "backdrop": { "$value": "#00000066" }
    }
