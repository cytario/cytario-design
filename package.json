{
  "name": "@cytario/design",
  "version": "0.0.0-development",
  "description": "Cytario design system and brand portal",
  "repository": {
    "type": "git",
    "url": "https://github.com/cytario/cytario-design"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens/variables.css": "./src/tokens/variables.css",
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/tokens/variables.css",
    "src/styles"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "build:tokens": "node scripts/build-tokens.ts",
    "build:lib": "tsc --project tsconfig.build.json",
    "test": "vitest",
    "lint": "eslint src/",
    "release": "semantic-release"
  },
  "keywords": [],
  "author": "cytario",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "peerDependencies": {
    "lucide-react": ">=0.400.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "dependencies": {
    "react": "19.2.4",
    "react-aria-components": "1.15.1",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@storybook/addon-a11y": "10.2.10",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/react": "10.2.10",
    "@storybook/react-vite": "10.2.10",
    "@tailwindcss/vite": "4.2.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.0.1",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.575.0",
    "prettier": "3.8.1",
    "remark-gfm": "^4.0.1",
    "semantic-release": "^25.0.3",
    "storybook": "10.2.10",
    "style-dictionary": "5.3.2",
    "svgo": "4.0.0",
    "tailwindcss": "4.2.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
